# Copy to .env and set your key (used by docker compose)
GROQ_API_KEY=
# Optional: stronger layout copy (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.1-8b-instant
# Pollinations background model (default: flux)
# POLLINATIONS_MODEL=flux
# OUTPUT_DIR=/app/output
# USE_REMBG=true
# BRAND_TAGLINE=BY EXPERT FACULTY
# REFERENCE_DIR=assets/references

# Google Sheet columns:
# A = title, B = your photo (Drive link), C = status, D = optional custom background (Drive link)
